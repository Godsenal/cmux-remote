{
  "name": "cmux-remote",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": { "cmux-remote": "./bin/cmux-remote" },
  "scripts": {
    "start": "bun run server.ts",
    "install-cli": "zsh scripts/install-cli.sh",
    "build": "bun build --compile --minify server.ts --outfile cmux-remote",
    "postinstall": "CMUX_REMOTE_WIRE_ONLY=1 zsh scripts/install-autostart.sh || true"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/web-push": "^3.6.4"
  }
}
